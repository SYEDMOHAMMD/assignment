@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { background: linear-gradient(rgb(253, 246, 255) 0%, rgb(255, 240, 248=
) 100%); display: flex; flex-direction: column; align-items: center; justif=
y-content: center; min-height: 100vh; font-family: Georgia, serif; overflow=
: hidden; }

.message { font-size: 2rem; color: rgb(176, 92, 130); text-align: center; m=
argin-bottom: 10px; letter-spacing: 2px; opacity: 0; animation: 1.5s ease 2=
.5s 1 normal forwards running fadeIn; }

.subtitle { font-size: 1rem; color: rgb(201, 139, 176); margin-bottom: 30px=
; opacity: 0; animation: 1.5s ease 3s 1 normal forwards running fadeIn; }

.apology { font-size: 1.1rem; color: rgb(157, 75, 110); text-align: center;=
 margin-top: 28px; font-style: italic; opacity: 0; animation: 2s ease 5s 1 =
normal forwards running fadeIn; letter-spacing: 1px; }

@keyframes fadeIn {=20
  100% { opacity: 1; }
}

.scene { position: relative; width: 380px; height: 420px; }

.stem { position: absolute; bottom: 60px; width: 5px; background: rgb(90, 1=
56, 74); border-radius: 4px; transform-origin: center bottom; animation: 3s=
 ease-in-out 0s infinite normal none running sway; }

.stem:nth-child(2n+1) { animation-direction: alternate; }

.stem:nth-child(2n) { animation-direction: alternate-reverse; }

@keyframes sway {=20
  0% { transform: rotate(-2deg); }
  100% { transform: rotate(2deg); }
}

.leaf { position: absolute; width: 22px; height: 12px; background: rgb(106,=
 185, 84); border-radius: 50% 50% 50% 0px; transform-origin: left bottom; }

.flower { position: absolute; transform-origin: center bottom; animation: 1=
s cubic-bezier(0.34, 1.56, 0.64, 1) 0s 1 normal both running bloom, 3s ease=
-in-out 0s infinite normal none running sway; }

@keyframes bloom {=20
  0% { transform: scale(0) rotate(-15deg); opacity: 0; }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.petals { position: relative; width: 70px; height: 70px; }

.petal { position: absolute; width: 26px; height: 38px; border-radius: 50%;=
 top: 50%; left: 50%; transform-origin: center bottom; opacity: 0.92; }

.center { position: absolute; width: 22px; height: 22px; border-radius: 50%=
; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10; box-s=
hadow: rgba(0, 0, 0, 0.15) 0px 2px 4px inset; }

.wrapper { position: absolute; bottom: 0px; left: 50%; transform: translate=
X(-50%); width: 120px; height: 100px; }

.wrapper-shape { width: 0px; height: 0px; border-left: 60px solid transpare=
nt; border-right: 60px solid transparent; border-top: 90px solid rgb(247, 2=
00, 220); position: absolute; top: 10px; left: 0px; filter: drop-shadow(rgb=
a(180, 80, 120, 0.15) 0px 2px 4px); }

.wrapper-stripe { position: absolute; width: 0px; height: 0px; border-left:=
 60px solid transparent; border-right: 60px solid transparent; border-top: =
90px solid rgba(255, 255, 255, 0.18); top: 10px; left: 0px; clip-path: poly=
gon(30% 0%, 50% 0%, 50% 100%, 25% 100%); }

.ribbon { position: absolute; bottom: 8px; left: 50%; transform: translateX=
(-50%); width: 40px; height: 14px; background: rgb(249, 168, 204); border-r=
adius: 3px; }

.ribbon::before, .ribbon::after { content: ""; position: absolute; top: 2px=
; left: -16px; width: 20px; height: 10px; background: rgb(249, 168, 204); b=
order-radius: 50%; transform: rotate(-30deg); }

.ribbon::after { left: auto; right: -16px; transform: rotate(30deg); }

.heart { position: absolute; font-size: 1.1rem; opacity: 0; animation: 4s e=
ase-in 0s infinite normal none running floatHeart; pointer-events: none; }

@keyframes floatHeart {=20
  0% { opacity: 0; transform: translateY(0px) scale(0.5); }
  20% { opacity: 0.8; }
  100% { opacity: 0; transform: translateY(-90px) scale(1.2); }
